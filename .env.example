# ─── Application ─────────────────────────────────────────────
TIA_APP_NAME="Tech Intelligence Agent"
TIA_TIMEZONE="Africa/Cairo"
TIA_LOG_LEVEL="INFO"
TIA_LOG_DIR="logs"

# ─── Database ────────────────────────────────────────────────
TIA_DATABASE_PATH="data/tech_intel.db"

# ─── Ollama (local LLM) ──────────────────────────────────────
TIA_OLLAMA_BASE_URL="http://localhost:11434"
TIA_OLLAMA_MODEL="qwen3:14b"
TIA_OLLAMA_TIMEOUT_SECONDS=180

# ─── Pipeline limits ─────────────────────────────────────────
TIA_MAX_ARTICLES_PER_SOURCE=20
TIA_MAX_SUMMARY_WORDS=120

# ─── Schedule (cron-style) ───────────────────────────────────
TIA_DAILY_COLLECT_HOUR=6
TIA_WEEKLY_REPORT_DAY="sun"
TIA_WEEKLY_REPORT_HOUR=9

# ─── Email (SMTP) ────────────────────────────────────────────
# For Gmail: use an App Password, never your account password.
TIA_SMTP_HOST="smtp.gmail.com"
TIA_SMTP_PORT=587
TIA_SMTP_USE_TLS=true
TIA_SMTP_USERNAME="you@example.com"
TIA_SMTP_PASSWORD="change-me"
TIA_EMAIL_FROM="you@example.com"
TIA_EMAIL_TO="you@example.com"

# ─── Config files (relative to project root) ─────────────────
TIA_SOURCES_FILE="app/core/config/sources.yaml"
TIA_SCORING_FILE="app/core/config/scoring.yaml"
